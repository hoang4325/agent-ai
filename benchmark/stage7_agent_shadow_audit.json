        "role": "model or provider identifier (e.g. gemini-2.5-pro / stub_v1)",
        "required": true,
        "agent_emits": true
      },
      "tactical_intent": {
        "role": "selected tactical intent from ALLOWED_AGENT_INTENTS",
        "required": true,
        "agent_emits": true
      },
