{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frozen Case Bundle Case Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_version",
    "case_id",
    "scenario_id",
    "status",
    "corpus_readiness",
    "determinism_level",
    "case_version",
    "build_timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "frozen_case_bundle_v1.schema.case_manifest",
      "x-population": "derived"
    },
    "bundle_version": {
      "type": "string",
      "const": "frozen_case_bundle_v1",
      "x-population": "derived"
    },
    "case_id": {
      "type": "string",
      "x-population": "existing_case_spec"
    },
    "scenario_id": {
      "type": "string",
      "x-population": "existing_case_spec"
    },
    "family": {
      "type": [
        "string",
        "null"
      ],
      "x-population": "existing_case_spec"
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "provisional",
        "planned"
      ],
      "x-population": "existing_case_spec"
    },
    "corpus_readiness": {
      "type": "string",
      "enum": [
        "corpus_ready",
        "corpus_partial",
        "corpus_pending"
      ],
      "x-population": "derived"
    },
    "determinism_level": {
      "type": "string",
      "x-population": "existing_case_spec"
    },
    "source": {
      "type": "string",
      "x-population": "existing_case_spec"
    },
    "owner": {
      "type": [
        "string",
        "null"
      ],
      "x-population": "existing_case_spec"
    },
    "case_version": {
      "type": "string",
      "x-population": "derived"
    },
    "build_timestamp": {
      "type": "string",
      "x-population": "derived"
    },
    "supported_benchmark_modes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "x-population": "existing_case_spec"
    },
    "pending_ground_truth_binding": {
      "type": "boolean",
      "x-population": "existing_case_spec"
    },
    "readiness_checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "x-population": "derived"
    },
    "bundle_paths": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      },
      "x-population": "derived"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "x-population": "derived"
    }
  }
}
