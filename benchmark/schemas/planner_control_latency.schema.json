    "execution_finalize_latency_ms": { "type": ["number", "null"] },
    "planner_execution_latency_ms": { "type": ["number", "null"] },
    "decision_to_execution_latency_ms": { "type": ["number", "null"] },
    "total_loop_latency_ms": { "type": ["number", "null"] },
    "latency_budget_ms": { "type": ["number", "null"] },
    "over_budget": { "type": ["boolean", "null"] },
    "over_budget_component": { "type": ["string", "null"] },
    "provenance": {
